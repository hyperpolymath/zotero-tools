{
  "manifest_version": 2,
  "name": "Zotero Voyant Export",
  "version": "2.1.0",
  "description": "Export your Zotero collections to Voyant",
  "author": "Cora Johnson-Roberson",
  "homepage_url": "https://github.com/Hyperpolymath/zotero-voyant-export",
  "applications": {
    "zotero": {
      "id": "voyant-export@hyperpolymath",
      "update_url": "https://raw.githubusercontent.com/hyperpolymath/zotero-tools/main/voyant-export/update.json",
      "strict_min_version": "7.0",
      "strict_max_version": "8.99"
    }
  },
  "icons": {
    "64": "ui/icon.png"
  }
}
